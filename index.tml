<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MiniPOS Cloud</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Barra de Navegación -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="#"><i class="fas fa-cash-register me-2"></i>MiniPOS Cloud</a>
            <div class="navbar-nav ms-auto flex-row">
                <button class="btn btn-outline-light btn-sm me-2" onclick="switchTab('pos')"><i class="fas fa-store me-1"></i> Caja</button>
                <button class="btn btn-outline-light btn-sm" onclick="switchTab('dashboard')"><i class="fas fa-chart-line me-1"></i> Dashboard</button>
            </div>
        </div>
    </nav>

    <main class="container py-3">
        <!-- VISTA DE CAJA (POS) -->
        <div id="view-pos" class="row">
            <div class="col-lg-7 mb-4">
                <h5 class="fw-bold text-secondary mb-3">Catálogo de Productos</h5>
                <div class="row row-cols-2 row-cols-md-3 g-2" id="product-grid">
                    <!-- Se llena con JavaScript -->
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-shopping-cart me-2"></i>Venta Actual</h5>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush" id="cart-items" style="max-height: 250px; overflow-y: auto;">
                            <li class="list-group-item text-center text-muted py-4">El carrito está vacío</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-white py-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold fs-5">Total:</span>
                            <span class="fw-bold fs-5 text-success" id="cart-total">$U 0.00</span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Método de Pago</label>
                            <select class="form-select form-select-sm" id="payment-method">
                                <option value="Efectivo">Efectivo</option>
                                <option value="Tarjeta">Tarjeta de Crédito / Débito</option>
                            </select>
                        </div>
                        <button class="btn btn-success w-100 py-2 fw-bold" onclick="checkout()"><i class="fas fa-check-circle me-2"></i>Cobrar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- VISTA DE DASHBOARD -->
        <div id="view-dashboard" class="row" style="display: none;">
            <div class="col-12 mb-3">
                <h5 class="fw-bold text-secondary">Panel de Control / Back Office</h5>
            </div>
            <div class="col-6 mb-3">
                <div class="card shadow-sm border-0 bg-white">
                    <div class="card-body py-2">
                        <small class="text-muted fw-bold">Ingresos Totales</small>
                        <h5 class="fw-bold text-success mb-0" id="dash-revenue">$U 0.00</h5>
                    </div>
                </div>
            </div>
            <div class="col-6 mb-3">
                <div class="card shadow-sm border-0 bg-white">
                    <div class="card-body py-2">
                        <small class="text-muted fw-bold">Transacciones</small>
                        <h5 class="fw-bold text-primary mb-0" id="dash-count">0</h5>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-2">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-history me-2"></i>Historial de Ventas</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle small">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Método</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody id="sales-history">
                                    <tr><td colspan="3" class="text-center text-muted py-3">Sin ventas registradas</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Script de lógica de la aplicación -->
    <script>
        // Base de datos local simulada
        let products = [
            { id: 1, name: 'Café Expreso', price: 120.0, stock: 50 },
            { id: 2, name: 'Medialuna', price: 55.0, stock: 100 },
            { id: 3, name: 'Jugo de Naranja', price: 150.0, stock: 30 }
        ];
        let cart = [];
        let sales = [];

        function renderProducts() {
            let grid = document.getElementById('product-grid');
            grid.innerHTML = '';
            products.forEach(p => {
                grid.innerHTML += `
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 text-center p-2" style="cursor: pointer;" onclick="addToCart(${p.id})">
                            <h6 class="fw-bold text-dark mb-1">${p.name}</h6>
                            <p class="text-success fw-bold mb-1">$U ${p.price.toFixed(2)}</p>
                            <span class="badge bg-light text-muted small">Stock: ${p.stock}</span>
                        </div>
                    </div>`;
            });
        }

        function addToCart(id) {
            let p = products.find(x => x.id === id);
            let item = cart.find(x => x.id === id);
            if (item) {
                if (item.quantity < p.stock) item.quantity++;
                else alert('Stock máximo alcanzado');
            } else {
                if (p.stock > 0) cart.push({ id: p.id, name: p.name, price: p.price, quantity: 1 });
                else alert('Producto sin stock');
            }
            renderCart();
        }

        function updateQty(id, delta) {
            let item = cart.find(x => x.id === id);
            let p = products.find(x => x.id === id);
            if (item) {
                item.quantity += delta;
                if (item.quantity <= 0) cart = cart.filter(x => x.id !== id);
                renderCart();
            }
        }

        function renderCart() {
            let container = document.getElementById('cart-items');
            let totalEl = document.getElementById('cart-total');
            if (cart.length === 0) {
                container.innerHTML = '<li class="list-group-item text-center text-muted py-4">El carrito está vacío</li>';
                totalEl.innerText = '$U 0.00';
                return;
            }
            let html = '';
            let total = 0;
            cart.forEach(i => {
                total += i.price * i.quantity;
                html += `<li class="list-group-item d-flex justify-content-between align-items-center py-2">
                    <div>
                        <span class="fw-bold small">${i.name}</span><br>
                        <small class="text-muted">$U ${i.price} x ${i.quantity}</small>
                    </div>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary px-2" onclick="updateQty(${i.id}, -1)">-</button>
                        <button class="btn btn-outline-secondary px-2 disabled">${i.quantity}</button>
                        <button class="btn btn-outline-secondary px-2" onclick="updateQty(${i.id}, 1)">+</button>
                    </div>
                </li>`;
            });
            container.innerHTML = html;
            totalEl.innerText = '$U ' + total.toFixed(2);
        }

        function checkout() {
            if (cart.length === 0) return alert('El carrito está vacío.');
            let total = cart.reduce((sum, i) => sum + (i.price * i.quantity), 0);
            let method = document.getElementById('payment-method').value;

            // Descontar stock
            cart.forEach(i => {
                let p = products.find(x => x.id === i.id);
                if (p) p.stock -= i.quantity;
            });

            sales.push({ id: sales.length + 1, total, method });
            cart = [];
            renderCart();
            renderProducts();
            updateDashboard();
            alert('¡Venta realizada con éxito!');
            switchTab('dashboard');
        }

        function updateDashboard() {
            let totalRev = sales.reduce((sum, s) => sum + s.total, 0);
            document.getElementById('dash-revenue').innerText = '$U ' + totalRev.toFixed(2);
            document.getElementById('dash-count').innerText = sales.length;

            let historyEl = document.getElementById('sales-history');
            if (sales.length === 0) {
                historyEl.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">Sin ventas registradas</td></tr>';
                return;
            }
            let html = '';
            sales.slice().reverse().forEach(s => {
                html += `<tr>
                    <td>#${s.id}</td>
                    <td><span class="badge bg-light text-dark border">${s.method}</span></td>
                    <td class="fw-bold text-success">$U ${s.total.toFixed(2)}</td>
                </tr>`;
            });
            historyEl.innerHTML = html;
        }

        function switchTab(tab) {
            if (tab === 'pos') {
                document.getElementById('view-pos').style.display = 'flex';
                document.getElementById('view-dashboard').style.display = 'none';
            } else {
                document.getElementById('view-pos').style.display = 'none';
                document.getElementById('view-dashboard').style.display = 'flex';
            }
        }

        renderProducts();
    </script>
</body>
</html>
